{
  "name": "vrcsm-web",
  "version": "0.15.1",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "vitest run src/__tests__/pages-smoke.test.tsx src/__tests__/interaction-smoke.test.tsx",
    "test:ui-smoke": "playwright test",
    "test:ui-smoke:update": "playwright test --update-snapshots",
    "i18n:translate": "node scripts/i18n-translate.mjs",
    "i18n:check": "node scripts/i18n-translate.mjs --dry-run"
  },
  "dependencies": {
    "@fontsource/geist-mono": "^5.2.7",
    "@fontsource/geist-sans": "^5.2.5",
    "@huggingface/transformers": "^4.1.0",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@react-three/drei": "^10.0.0",
    "@react-three/fiber": "^9.0.0",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-virtual": "^3.14.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^0.456.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.7.4",
    "react-resizable-panels": "^4.10.0",
    "react-router-dom": "^6.30.3",
    "sonner": "^1.7.1",
    "tailwind-merge": "^2.6.0",
    "three": "^0.169.0"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.0",
    "@types/pngjs": "6.0.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.5.2",
    "jsdom": "^29.0.2",
    "pixelmatch": "7.2.0",
    "pngjs": "7.0.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
